# Database Configuration
MONGO_URL=mongodb://localhost:27017/bqplay

# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# JWT Secret (REQUIRED - generate a strong random string)
JWT_SECRET=your-strong-secret-key-here

# RapidAPI (Cricbuzz) Configuration (Optional - for live international data)
# Sign up at: https://rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_CRICKET_HOST=free-cricbuzz-cricket-api.p.rapidapi.com
RAPIDAPI_LIVE_MATCHES_PATHS=/cricket-matches-live,/cricket-livescores
RAPIDAPI_UPCOMING_MATCHES_PATHS=/cricket-schedule-international,/cricket-matches-upcoming
RAPIDAPI_RECENT_MATCHES_PATHS=/cricket-matches-recent
RAPIDAPI_MATCH_INFO_PATHS=/cricket-match-info?matchid={id}
RAPIDAPI_SERIES_INTERNATIONAL_PATHS=/cricket-series-international
RAPIDAPI_SERIES_LEAGUE_PATHS=/cricket-series-leagues
RAPIDAPI_SERIES_DOMESTIC_PATHS=/cricket-series-domestic

# Free Cricbuzz API (Optional - alternative to RapidAPI)
ENABLE_FREE_CRICBUZZ=false
FREE_CRICBUZZ_BASE_URL=

# Legacy Cricket API Configuration (Optional)
# Get your API key from: https://cricketdata.org/
CRICKET_API_KEY=your_api_key_here
CRICKET_API_PROVIDER=cricapi
CRICKET_POLL_INTERVAL=180

# YouTube Data API v3 (Optional - for highlights & videos)
# Get from: https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google OAuth (Optional - for Google login)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# AI Commentary Configuration (Optional)
AI_PROVIDER=claude           # or "openai"
AI_MODEL=claude-sonnet-4-20250514

# Anthropic Claude API (Optional - for AI commentary)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (Optional - fallback if AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# External Sync (Optional)
ENABLE_EXTERNAL_SYNC=false
EXTERNAL_SYNC_BASE_URL=
SYNC_INTERVAL=30

# Sentry Error Tracking (Optional)
# Get DSN from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
SENTRY_DSN=
